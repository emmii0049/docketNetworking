{
  "name": "Container Network Security Lab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",



  "customizations": {
    "vscode": {
      "extensions": [
        "github.codespaces",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y iputils-ping curl wget",
  "postStartCommand": "docker info && bash /workspaces/docketNetworking/check.sh",

  "remoteUser": "codespace",

  "forwardPorts": [8080],

  "portsAttributes": {
    "8080": {
      "label": "Nginx Web Server",
      "onAutoForward": "openBrowser"
    }
  }
}